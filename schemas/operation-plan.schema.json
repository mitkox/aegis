{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aegis OperationPlan",
  "type": "object",
  "required": [
    "plan_id",
    "created_at",
    "tool",
    "operation",
    "metadata_available",
    "command_preview",
    "mutates_system",
    "requires_root",
    "network_access",
    "packages_installed",
    "packages_upgraded",
    "packages_removed",
    "packages_downgraded",
    "packages_held_back",
    "scripts_detected",
    "build_hooks_detected",
    "native_code_risk",
    "binary_artifact_risk",
    "mutable_reference",
    "risk_signals",
    "warnings",
    "raw_evidence"
  ],
  "properties": {
    "plan_id": { "type": "string" },
    "created_at": { "type": "string" },
    "tool": {
      "enum": ["apt", "npm", "pip", "container", "nuget", "vscode", "go", "cargo"]
    },
    "operation": { "type": "string" },
    "ecosystem": { "type": "string" },
    "target_type": { "type": "string" },
    "target": { "type": "string" },
    "target_version": { "type": "string" },
    "source_registry": { "type": "string" },
    "metadata_available": { "type": "boolean" },
    "command_preview": { "type": "array", "items": { "type": "string" } },
    "mutates_system": { "type": "boolean" },
    "requires_root": { "type": "boolean" },
    "network_access": { "type": "boolean" },
    "packages_installed": { "type": "array", "items": { "type": "string" } },
    "packages_upgraded": { "type": "array", "items": { "type": "string" } },
    "packages_removed": { "type": "array", "items": { "type": "string" } },
    "packages_downgraded": { "type": "array", "items": { "type": "string" } },
    "packages_held_back": { "type": "array", "items": { "type": "string" } },
    "scripts_detected": { "type": "array", "items": { "type": "string" } },
    "build_hooks_detected": { "type": "array", "items": { "type": "string" } },
    "native_code_risk": { "type": "boolean" },
    "binary_artifact_risk": { "type": "boolean" },
    "signature_or_checksum_status": { "type": "string" },
    "mutable_reference": { "type": "boolean" },
    "publisher_or_maintainer": { "type": "string" },
    "transitive_dependency_count": { "type": "integer" },
    "risk_signals": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "raw_evidence": { "type": "object" }
  }
}
