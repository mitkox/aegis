{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aegis ExecutionPlan",
  "type": "object",
  "required": [
    "schema_version",
    "execution_plan_id",
    "operation_plan_id",
    "policy_decision",
    "policy_version",
    "evaluator_hash",
    "argv",
    "exact_targets",
    "required_preflight_checks",
    "required_controls",
    "signer_identity",
    "created_at",
    "expires_at",
    "approvals",
    "operation_plan_hash",
    "policy_result_hash",
    "operation_plan",
    "policy_result",
    "control_proofs",
    "signature"
  ],
  "properties": {
    "schema_version": { "type": "integer" },
    "execution_plan_id": { "type": "string" },
    "operation_plan_id": { "type": "string" },
    "policy_decision": { "enum": ["allow", "allow_with_snapshot", "require_human", "deny"] },
    "policy_version": { "type": "string" },
    "evaluator_hash": { "type": "string" },
    "argv": { "type": "array", "items": { "type": "string" } },
    "exact_targets": { "type": "array", "items": { "type": "string" } },
    "required_preflight_checks": { "type": "array", "items": { "type": "string" } },
    "required_controls": { "type": "array", "items": { "type": "string" } },
    "rollback_plan": { "type": ["object", "null"] },
    "signer_identity": { "type": "string" },
    "created_at": { "type": "string" },
    "expires_at": { "type": "string" },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signer", "role", "reason", "approved_at", "expires_at", "plan_hash", "signature"],
        "properties": {
          "signer": { "type": "string" },
          "role": { "type": "string" },
          "reason": { "type": "string" },
          "approved_at": { "type": "string" },
          "expires_at": { "type": "string" },
          "plan_hash": { "type": "string" },
          "signature": {
            "type": "object",
            "required": ["algorithm", "key_id", "signature"],
            "properties": {
              "algorithm": { "type": "string" },
              "key_id": { "type": "string" },
              "signature": { "type": "string" }
            }
          }
        }
      }
    },
    "operation_plan_hash": { "type": "string" },
    "policy_result_hash": { "type": "string" },
    "operation_plan": { "type": "object" },
    "policy_result": { "type": "object" },
    "control_proofs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["control", "proof_type", "value", "created_at"],
        "properties": {
          "control": { "type": "string" },
          "proof_type": { "type": "string" },
          "value": { "type": "string" },
          "created_at": { "type": "string" },
          "expires_at": { "type": "string" }
        }
      }
    },
    "ai_review_hash": { "type": "string" },
    "signature": {
      "type": "object",
      "required": ["algorithm", "key_id", "signature"],
      "properties": {
        "algorithm": { "type": "string" },
        "key_id": { "type": "string" },
        "signature": { "type": "string" }
      }
    }
  }
}
